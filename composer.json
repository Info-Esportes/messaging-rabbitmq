{
    "name": "infoesportes/messaging-rabbitmq",
    "description": "Framework-agnostic messaging core for RabbitMQ with support for Email, SMS, and WhatsApp",
    "type": "library",
    "keywords": [
        "rabbitmq",
        "messaging",
        "microservice",
        "email",
        "sms",
        "whatsapp",
        "amqp",
        "queue"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Lucas Pinheiro",
            "email": "contact@infoesportes.com",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/infoesportes/messaging-rabbitmq/issues",
        "source": "https://github.com/infoesportes/messaging-rabbitmq"
    },
    "require": {
        "php": "^8.0|^8.1|^8.2|^8.3",
        "php-amqplib/php-amqplib": "^3.5|^4.0",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.40"
    },
    "suggest": {
        "ext-pcntl": "Required for graceful shutdown in consumers",
        "psr/log": "For logging support"
    },
    "autoload": {
        "psr-4": {
            "InfoEsportes\\Messaging\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "InfoEsportes\\Messaging\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "phpstan": "vendor/bin/phpstan analyse src tests --level=8",
        "cs-fix": "vendor/bin/php-cs-fixer fix",
        "cs-check": "vendor/bin/php-cs-fixer fix --dry-run --diff"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}